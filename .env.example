# ===================================================================
# Ap-Ab — variables de entorno del BACKEND (Netlify Function)
# -------------------------------------------------------------------
# NO subas el archivo .env real al repo (ya está en .gitignore).
# Estos valores se configuran en: Netlify → Site → Settings →
# Environment variables. NUNCA van en el cliente.
# ===================================================================

# --- Supabase (panel → Project Settings → API) ---
SUPABASE_URL=https://TU-PROYECTO.supabase.co
# service_role: ¡SECRETA! Da acceso total. Solo aquí, jamás en el navegador.
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...service_role...

# --- Modo IA (Anthropic) ---
# true para activar el Asistente IA; false para solo modo gratis.
AI_MODE_ENABLED=true
# API key de Anthropic (console.anthropic.com). Solo backend.
ANTHROPIC_API_KEY=sk-ant-...
# Modelo más barato. Verifica el string vigente en docs.claude.com.
ANTHROPIC_MODEL=claude-haiku-4-5

# --- Pago del paquete de 10 cotizaciones (US$5) — lo conecta el arquitecto ---
# Signing secret del webhook de Stripe (Developers → Webhooks).
STRIPE_WEBHOOK_SECRET=whsec_...
# Cuántas cotizaciones acredita cada compra (por defecto 10).
PACK_SIZE=10
# NOTA: el enlace de pago (Payment Link público) NO va aquí, va en
# assets/supabase-config.js -> PAYMENT_LINK.
